{
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"]
    },
    "analyzer": {
      "command": "uvx",
      "args": ["mcp-server-analyzer"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "planka": {
      "url": "http://localhost:25478/mcp"
    },
     "obsidian": {
      "command": "npx",
      "args": ["@bitbonsai/mcpvault@latest", "${workspaceFolder}"]
    }
  }
}