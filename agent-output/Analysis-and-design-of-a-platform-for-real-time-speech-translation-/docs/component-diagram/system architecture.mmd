%% System Architecture Diagram (Mermaid) - Orchestrated Hub-and-Spoke
%% Last Updated: 2026-03-13

flowchart TB
    %% External Clients
    Client["External_Clients\n(Web/Mobile/CLI)"]:::external
    UI["Demo Web UI\n(Epic 2.7)"]:::external
    Bench["Benchmark Harness\n(load runner + metrics collector)"]:::external
    IaC["Pulumi IaC Blueprint\n(Epic 3.0)\n(reproducible Swarm infra)"]:::external

    %% Shared Infrastructure
    subgraph Infra[Shared Infrastructure]
      Kafka[(Kafka)]:::infra
      SR[(Schema Registry)]:::infra
      Obj[("Object Store (Optional)\nMinIO/S3")]:::infra
      Ray[("Ray Cluster (Optional)\nHead + Workers")]:::infra
    end

    Contract["Shared Contract Artifact\n(Avro .avsc + envelope\n+ optional generated bindings)"]:::shared

    %% Services
    subgraph Services[Independent Microservices]
      BFF["BFF Gateway\n(primary browser/runtime edge)\n(session + bridge boundary)"]:::svc
      GW["Ingress Gateway\n(WebSocket + HTTP upload)\n(internal-only in Swarm/IaC)"]:::svc
      Orch["Pipeline Orchestrator\n(Epic 3.6)\n(Workflow, State & Guardrails)"]:::svc
      
      subgraph Workers[AI Worker Services]
          VAD["VAD Service\n(silence removal)"]:::svc
          ASR["ASR Service\n(audio → text)"]:::svc
          TR["Translation Service\n(text → translated text)"]:::svc
          TTS["TTS Service\n(Kokoro-82M ONNX)\n(text → audio)"]:::svc
      end
    end

    %% Cross-cutting concerns
    subgraph CrossCutting[Cross-cutting Concerns]
      Obs["Privacy-safe Observability\n(Normal vs Debug, trace allowlist)"]:::shared
      Guard["Runtime Guardrails (Epic 3.7)\n(Hallucination filtering, drop empty)"]:::shared
    end

    %% Gateway & Client interactions
    IaC -. "provisions infra" .-> Infra
    Client -->|WebSocket/HTTP| BFF
    UI -->|WebSocket/HTTP| BFF
    Bench -->|HTTP/WebSocket| BFF
    BFF -->|internal adapter calls| GW
    Bench -. "Consume results" .-> Kafka
    BFF -->|"WebSocket /sessions"| UI

    %% NEW ORCHESTRATED FLOW (Hub and Spoke via Kafka)
    %% 1. Ingress to Orchestrator
    GW -->|"speech.audio.ingress\nAudioInputEvent"| Kafka
    Kafka -->|"speech.audio.ingress"| Orch

    %% 2. Orchestrator <-> VAD
    Orch -->|"speech.vad.command"| Kafka
    Kafka -->|"speech.vad.command"| VAD
    VAD -->|"speech.audio.speech_segment"| Kafka
    Kafka -->|"speech.audio.speech_segment"| Orch

    %% 3. Orchestrator <-> ASR
    Orch -->|"speech.asr.command\n(Guardrails applied)"| Kafka
    Kafka -->|"speech.asr.command"| ASR
    ASR -->|"speech.asr.text\nTextRecognizedEvent"| Kafka
    Kafka -->|"speech.asr.text"| Orch

    %% 4. Orchestrator <-> Translation
    Orch -->|"speech.translation.command\n(Guardrails applied)"| Kafka
    Kafka -->|"speech.translation.command"| TR
    TR -->|"speech.translation.text\nTextTranslatedEvent"| Kafka
    Kafka -->|"speech.translation.text"| Orch

    %% 5. Orchestrator <-> TTS & Back to Gateway
    Orch -->|"speech.tts.command"| Kafka
    Kafka -->|"speech.tts.command"| TTS
    TTS -->|"speech.tts.audio\nAudioSynthesisEvent"| Kafka
    Kafka -->|"speech.tts.audio"| GW

    %% Link Orchestrator to Guardrails explicitly
    Orch -. "enforces" .-> Guard

    %% Claim Check Pattern (unchanged)
    GW -. "audio_uri = s3://{bucket}/{key}" .-> Obj
    VAD -. "segment_uri = s3://{bucket}/{key}" .-> Obj
    ASR -. "transcript_uri = s3://{bucket}/{key}" .-> Obj
    TTS -. "audio_uri = s3://{bucket}/{key}" .-> Obj

    %% Known deviation
    Deviate["Known deviation: TTS can emit presigned URLs (forbidden)"]:::warn
    Deviate --- TTS

    %% Observability & Registries
    Obs -. "policy" .-> GW
    Obs -. "policy" .-> Orch
    Obs -. "policy" .-> Workers
    
    Workers --- SR
    GW --- SR
    Orch --- SR
    Contract --- Workers
    Contract --- GW
    Contract --- Orch

    %% Ray execution
    Workers -. "Internal execution (feature-flagged)" .-> Ray

