flowchart LR
    subgraph STARTUP [Startup capability discovery]
        direction TB
        TM[Translation models loaded] --> TCAP["Build translation capability matrix<br/>allowed source-target pairs"]
        TTM["TTS models loaded<br/>Kokoro and Plapre"] --> TTSCAP["Build TTS capability matrix<br/>language-model-voice tuples"]
        TCAP --> GWREG[Gateway capability snapshot]
        TTSCAP --> GWREG
    end

    U[User] -->|GET capabilities| GWAPI[Gateway capabilities API]
    GWAPI -->|returns source languages target languages allowed pairs available voices per language| U
    U -->|selects source target voice| REQ["Session request tuple<br/>source target voice"]

    REQ --> GWP{"Tuple valid in<br/>gateway snapshot?"}
    GWP -->|no| GFAIL["Reject at gateway<br/>unsupported pair or voice"]
    GWP -->|yes| PIPE[Pipeline execution]

    PIPE --> AIN[AudioInputEvent]
    AIN --> VAD[VAD]
    VAD --> ASR[ASR]
    ASR --> TXT[TextRecognizedEvent]
    TXT --> MTSEL{"Translation pair<br/>in capability matrix?"}
    MTSEL -->|no| TFAIL["Reject translation<br/>unsupported pair"]
    MTSEL -->|yes| MT[Translation using selected model]
    MT --> TTXT[TextTranslatedEvent]

    TTXT --> TTSSEL{"Tuple target and voice<br/>in TTS capability matrix?"}
    TTSSEL -->|no| SFAIL["Reject TTS<br/>unsupported language or voice"]
    TTSSEL -->|yes| TTSRUN[TTS selected backend and voice]

    subgraph TTSROUTE [TTS route resolved from matrix]
        direction TB
        TTSRUN --> BACKEND{Resolved backend}
        BACKEND -->|Plapre tuple for da voices| PRT[Plapre synthesis]
        BACKEND -->|Kokoro tuple for language voices| KRT[Kokoro synthesis]
    end

    PRT --> OUT[WAV output]
    KRT --> OUT