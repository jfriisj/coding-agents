flowchart TB
    subgraph Sessions [Active User Sessions]
        UserA([User Session A])
        UserB([User Session B])
    end

    subgraph Kafka [Kafka Topic: speech.audio.speech_segment]
        direction TB
        P0["Partition 0\n(Key: Session A)"]
        P1["Partition 1\n(Key: Session B)"]
    end

    subgraph ConsumerGroup ["Service: ASR (Replicas: 2)"]
        direction TB
        R1["ASR Replica 1\n(Consumes P0)"]
        R2["ASR Replica 2\n(Consumes P1)"]
    end
    
    UserA -->|Produce| P0
    UserB -->|Produce| P1
    
    P0 ==> R1
    P1 ==> R2
    
    R1 -->|Process| Out1["Output A"]
    R2 -->|Process| Out2["Output B"]

    style P0 fill:#ffccbc
    style P1 fill:#b2dfdb
    style R1 fill:#ffccbc,stroke:#bf360c
    style R2 fill:#b2dfdb,stroke:#004d40