sequenceDiagram
    participant ASR as ASR Service
    participant MT as Translation Service
    
    Note over ASR, MT: Time Axis (t) --->

    %% Segment 1
    ASR->>ASR: Process Segment 1
    ASR->>MT: Event 1 (Ready)
    activate MT
    MT->>MT: Translate Segment 1
    
    %% Segment 2 starter MENS MT arbejder på 1
    par Pipeline Overlap
        MT-->>MT: (Still working on 1...)
        ASR->>ASR: Process Segment 2
    end
    
    MT->>MT: Emit Result 1
    deactivate MT
    
    ASR->>MT: Event 2 (Ready)
    activate MT
    MT->>MT: Translate Segment 2
    deactivate MT