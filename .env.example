# --- Netværk & Cloudflare ---
# If you want to use Cloudflare Tunnel, set the TUNNEL_TOKEN variable to your tunnel token. You can find this token in your Cloudflare dashboard under the "Access" section, then "Tunnels". If you don't want to use Cloudflare Tunnel, simply leave this variable empty.
TUNNEL_TOKEN=

# --- Database ---
DB_USER=postgres
DB_PASSWORD=ChooseAStrongPassword123
DB_NAME=planka

# --- Planka Security & Admin ---
SECRET_KEY=indsæt_en_meget_lang_tilfældig_streng_her
ADMIN_EMAIL=jonfjakobsen@gmail.com
ADMIN_PASSWORD=Rosa2009
ADMIN_NAME=Jon Friis Jakobsen
ADMIN_USERNAME=jonfriis
PLANKA_URL=http://localhost
PLANKA_PORT=1337
# Important: This MUST be your public domain or IP address if you want to access Planka from outside. It can be something like https://planka.yourdomain.com or http://your-ip-address:1337.
PLANKA_PUBLIC_URL=https://planka.friis-jakobsen.dk

# --- MCP Indstillinger ---
# Create a user for copilot in Planka with the email and password below, and ensure they have admin privileges.
MCP_PORT=25478
MCP_PLANKA_EMAIL=copilot@localhost.com
MCP_PLANKA_PASSWORD=Copilot123!

# --- Obsidian ---
OBSIDIAN_VAULT_PATH=./
PUID=1000
PGID=1000
TZ=Europe/Copenhagen
DOCKER_MODS=linuxserver/mods:universal-package-install
CONFIG_PATH=./obsidian-config
HTTP_PORT=3000
HTTPS_PORT=3001
API_PORT=27124
